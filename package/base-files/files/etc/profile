#!/bin/sh

# 颜色定义
White="\033[0m"
Yellow="\033[33m"
Red="\033[31m"
Blue="\033[34m"
Green="\033[32m"
Cyan="\033[36m"

# 显示Banner
show_banner() {
    clear
    if [ -f /etc/banner ]; then
        echo -e "${Yellow}$(cat /etc/banner)${White}"
    else
        echo -e "${Yellow}==========================================="
        echo -e " ImmortalWrt 系统管理工具"
        echo -e " zxmlysxl"
        echo -e "===========================================${White}"
    fi
    echo
}

# 确认函数
confirm_action() {
    local prompt="$1"
    echo -n "${prompt} [y/N]: "
    read confirm
    case "$confirm" in
        [yY][eE][sS]|[yY]) return 0 ;;
        *) return 1 ;;
    esac
}

# 函数：显示系统信息
sysinfo() {
    # 获取基本信息
    FIRMWARE_VERSION=$(grep "DISTRIB_DESCRIPTION" /etc/openwrt_release | awk -F "'" '{print $2}')
    [ -z "$FIRMWARE_VERSION" ] && FIRMWARE_VERSION="未知版本"
    HOSTNAME=$(uci get system.@system[0].hostname 2>/dev/null || echo "未知主机名")
    KERNEL_VERSION=$(uname -r)
    TARGET_PROFILE=$(jsonfilter -e '@.model.id' < /etc/board.json | tr ',' '_')
    DISTRIB_ARCH=$(grep "DISTRIB_ARCH" /etc/openwrt_release | awk -F "'" '{print $2}')
    
    # 系统架构判断
    if grep -Eq "x86" "/etc/openwrt_release"; then
        [ -d /sys/firmware/efi ] && ARCH="${DISTRIB_ARCH} - UEFI" || ARCH="${DISTRIB_ARCH} - BIOS"
    else
        ARCH="${DISTRIB_ARCH}"
    fi

    # 内存和存储信息
    Mem_total=$(awk '/MemTotal/{printf "%.0fMB\n", $2/1024}' /proc/meminfo)
    Overlay_Available=$(df -h | grep ":/overlay" | awk '{print $4}')
    Tmp_Available=$(df -h | grep "/tmp" | awk '{print $4}')
    Sys_time=$(awk '{d=$1/86400;h=($1%86400)/3600;m=($1%3600)/60;s=$1%60} {printf("%d天 %d小时 %d分钟 %d秒",d,h,m,s)}' /proc/uptime)

    # CPU信息
    CPU_Model=$(grep "model name" /proc/cpuinfo | head -n1 | awk -F ': ' '{print $2}')

    # 网络接口信息
    echo -e "${Yellow}=== 网络接口状态 ===${White}"
    printf "%-12s %-16s %-16s %-16s\n" "接口(type)" "网卡(Interface)" "状态(Status)" "速度(Speed)"
    
    for iface in $(ls /sys/class/net/ | grep -v "lo"); do
        iftype=""
        status=""
        speed="-"
        
        # 获取接口类型
        if uci get network.lan.ifname 2>/dev/null | grep -q "$iface"; then
            iftype="lan"
        elif uci get network.wan.ifname 2>/dev/null | grep -q "$iface"; then
            iftype="wan"
        else iftype="-"
        fi
        
        # 获取接口状态
        if [ -f /sys/class/net/$iface/carrier ] && [ $(cat /sys/class/net/$iface/carrier 2>/dev/null) -eq 1 ]; then
            status="已连接up"
        else
            status="未连接down"
        fi
        
        # 获取接口速度
        if [ -f /sys/class/net/$iface/speed ]; then
            speed_val=$(cat /sys/class/net/$iface/speed 2>/dev/null)
            if [ -n "$speed_val" ] && [ "$speed_val" -gt 0 ]; then
                if [ "$speed_val" -ge 1000 ]; then
                    speed=$(echo $speed_val | awk '{printf "%.1f Gb/s", $1/1000}')
                else
                    speed="${speed_val} Mb/s"
                fi
            fi
        fi
        
        printf "%-12s %-16s %-16s %-16s\n" " $iftype" "$iface" "$status" "$speed"
    done
    echo  #这里是空行

    # IP地址信息
    echo -e "${Yellow}=== IP地址信息 ===${White}"
    IPV4_INFO=$(ip -4 addr show br-lan 2>/dev/null | awk '/inet / {print $2}' | head -n1)
    IPV6_INFO=$(ip -6 addr show br-lan 2>/dev/null | awk '/inet6 / {print $2}' | head -n1)
    
    [ -n "$IPV4_INFO" ] && echo "IPv4 地址: ${IPV4_INFO}"
    [ -n "$IPV6_INFO" ] && echo "IPv6 地址: ${IPV6_INFO}"
    [ -z "$IPV4_INFO" ] && [ -z "$IPV6_INFO" ] && echo "未获取到IP地址信息"
    echo  #这里是空行

    # 显示所有信息
    echo -e "${Yellow}=== 系统信息 ===${White}"
    echo -e "${Cyan}固件版本: ${FIRMWARE_VERSION}${White}"
    echo -e "${Green}主机名称: ${HOSTNAME}${White} - ${Green}系统架构: ${ARCH}${White}"
    echo -e "${Cyan}内核版本: ${KERNEL_VERSION}${White}"
    echo -e "${Cyan}设备型号: ${TARGET_PROFILE}${White}"
    echo -e "${Green}CPU 型号: ${CPU_Model}${White}"
    echo -e "Overlay/TMP: ${Overlay_Available} / ${Tmp_Available} - ${Blue}内存总量: ${Mem_total}${White}"
    echo -e "${Red}运行时间: ${Sys_time}${White}"
    echo  #这里是空行
    echo -e "${Yellow}========================${White}"
    echo -e "${Blue}    zxmlysxl快捷菜单${White}"
    echo -e "${Yellow}========================${White}"
}

# 函数：主菜单
show_menu() {
    echo -e "${Green}1. 修改后台 IPv4 地址${White}"
    echo -e "${Green}2. 网卡绑定${White}"
    echo -e "${Green}3. 清除密码并重启${White}"
    echo -e "${Green}4. 重置网络和主题设置${White}"
    echo -e "${Green}5. 重启/关机${White}"
    echo -e "${Green}6. 重置系统${White}"
    echo -e "${Green}7. 网络检查${White}"
    echo -e "${Green}8. 释放内存${White}"
    echo -e "${Red}0. 退出${White}"
    echo -n "请输入选项 [0-8]: "
}

# 函数：修改IP地址
change_ip() {
    echo -n "输入新IP地址（如192.168.1.1）: "
    read new_ip
    if confirm_action "确定要将IP地址修改为$new_ip吗？"; then
        uci set network.lan.ipaddr="$new_ip"
        uci commit network
        echo "IP已修改为 $new_ip，请手动重启网络！"
    else
        echo "操作已取消"
    fi
    read -p "按回车键继续..."
}

# 主循环
while true; do
    show_banner
    sysinfo
    show_menu
    read choice
    case $choice in
        1) change_ip ;;
        2) 
            echo -e "${Yellow}网卡绑定功能暂未实现${White}"
            read -p "按回车键继续..."
            ;;
        3) 
            if confirm_action "确定要清除root密码并重启系统吗？"; then
                passwd -d root
                echo "root密码已清除，系统将重启..."
                reboot
            else
                echo "操作已取消"
                read -p "按回车键继续..."
            fi
            ;;
        4) 
            echo -e "${Yellow}重置功能暂未实现${White}"
            read -p "按回车键继续..."
            ;;
        5) 
            echo -e "${Yellow}=== 电源管理 ===${White}"
            echo -e "${Green}1. 重启系统${White}"
            echo -e "${Green}2. 关闭系统${White}"
            echo -n "请选择: "
            read power_choice
            case $power_choice in
                1) reboot ;;
                2) poweroff ;;
                *) echo -e "${Red}无效选择${White}";;
            esac
            ;;
        6) 
            if confirm_action "确定要恢复出厂设置吗？这将清除所有配置！"; then
                firstboot -y
                reboot
            else
                echo "操作已取消"
                read -p "按回车键继续..."
            fi
            ;;
        7) 
            echo -e "${Yellow}=== 网络检查 ===${White}"
            ping -c 3 223.5.5.5 && echo "外网连接正常" || echo "外网连接失败"
            read -p "按回车键继续..."
            ;;
        8) 
            if confirm_action "确定要释放内存吗？"; then
                echo "清除缓存中..."
                sync
                echo 3 > /proc/sys/vm/drop_caches
                echo "内存已释放"
            else
                echo "操作已取消"
            fi
            read -p "按回车键继续..."
            ;;
        0) 
            if confirm_action "确定要退出吗？"; then
                exit 0
            else
                echo "操作已取消"
                read -p "按回车键继续..."
            fi
            ;;
        *) 
            echo -e "${Red}无效选项，请重新输入！${White}" 
            sleep 1
            ;;
    esac
done


